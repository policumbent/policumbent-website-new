---
interface Props {
  image: string;
  firstName: string;
  lastName: string;
  role: string;
  socials?: {
    platform: string;
    url: string;
  }[];
}

const { image, firstName, lastName, role, socials = [] } = Astro.props;
---

<div class="profile-card">
  <div class="image-container">
    <img src={image} alt={`${firstName} ${lastName}`} />
  </div>

  <div class="content">
    <h3 class="name">{firstName} {lastName}</h3>
    <p class="role">{role}</p>
  </div>

  {socials.length > 0 && (
    <div class="social-links">
      {socials.map((link) => (
        <a href={link.url} target="_blank" rel="noopener noreferrer">
          {link.platform}
        </a>
      ))}
    </div>
  )}
</div>

<style>
    :root {
        --border-color: #000000;
        --bg-color: #252525; /* Grigio scuro dello sfondo */
        --text-color: #F4F7ED; /* Bianco */
        --btn-color: #A8C81E; /* Verde del pulsante */
        --btn-text: #F4F7ED;
        --link-color: #C4EC17; /* Verde dei link */
    }

  .profile-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 220px;
    background: var(--bg-color);
    padding: 20px;
    border: 3px solid var(--border-color);
    border-radius: 20px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .image-container {
    width: 180px;
    height: 180px;
    margin-bottom: 1.3rem;
  }

  @media (max-width: 768px) {
    .profile-card {
      width: 165px;
      padding: 15px;
      border: 2px solid var(--border-color);
    }

    .image-container {
      width: 130px;
      height: 130px;
    }

    .image-container img {
    width: 100%;
    height: 100%;
    border-radius: 15px;
    object-fit: cover;
    border: 2px solid var(--btn-color);
  }
  }

  .image-container img {
    width: 100%;
    height: 100%;
    border-radius: 15px;
    object-fit: cover;
    border: 3px solid var(--btn-color);
  }

  .content {
    text-align: center;
    margin-bottom: 1rem;
  }

  .name {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-color);
  }

  .role {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--link-color);
    text-transform: uppercase;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    border-top: 1px solid var(--btn-text);
    padding-top: 1rem;
    width: 100%;
    justify-content: center;
  }

  .social-links a {
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-color);
    text-decoration: underline;
    text-transform: capitalize;
    transition: color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--link-color);
  }
</style>