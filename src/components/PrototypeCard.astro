---
interface Props {
  image: string;
  name: string;
  years: string;
  category: string;
  link: string;
}

const { image, name, years, category, link } = Astro.props;
---

<div class="prototype-card">
  <div class="image-container">
    <img src={image} alt={name} />
  </div>

  <div class="content">
    <h2 class="name">{name}</h2>
    <p class="years">Years of activity: {years}</p>
    <p class="category"><i>{category}</i></p>
    <p><a href={link} rel="noopener noreferrer">Learn more &#8599;</a></p>
  </div>
</div>

<style>
  :root {
    --border-color: #000000;
    --bg-color: #252525; /* Grigio scuro dello sfondo */
    --text-color: #F4F7ED; /* Bianco */
    --btn-color: #A8C81E; /* Verde del pulsante */
    --btn-text: #F4F7ED;
    --link-color: #C4EC17; /* Verde dei link */
  }

  .prototype-card {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: 900px;
    max-height: 250px;
    background: var(--bg-color);
    border: 5px solid var(--link-color);
    border-radius: 20px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }

  .image-container {
    flex: 1;
    min-width: 0;
    height: auto;
    aspect-ratio: 1;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0px;
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem;
    color: var(--text-color);
  }

  .name {
    margin: 0 0 0.5rem 0;
    font-weight: bold;
    color: var(--text-color);
  }

  .years {
    margin: 0;
    color: var(--link-color);
    font-weight: 500;
  }

  .category {
    margin: 0;
    font-weight: 300;
    color: var(--text-color);
  }

  @media (max-width: 768px) {
    .prototype-card {
      flex-direction: column;
      max-width: 80%;
      max-height: none;
    }

    .image-container {
      aspect-ratio: 16 / 9;
    }

    .image-container img {
      border-right: none;
      border-bottom: 3px solid var(--btn-color);
    }

    .content {
      padding: 1.5rem;
      justify-content: flex-start;
    }
  }
</style>
